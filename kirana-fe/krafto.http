@baseUrl = https://alertpay.kiranaapps.com/api
@localUrl = http://localhost:8000/api

# Bearer token from Better Auth (get from login response)
@bearerToken = 7SNBqcNYl4WOu30s8RZcoEiHeGCxxCZG

### ===== KRAFTO / CRAFTO API =====
### These endpoints require authentication via Bearer token

### ===== CATEGORIES =====

### Get All Categories (Local)
# Returns all unique category types from the crafto_quotes table
# 
# Response (200 OK):
# {
#   "categories": ["category1", "category2", ...],
#   "count": 10
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
GET {{localUrl}}/crafto/categories
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get All Categories (Production)
GET {{baseUrl}}/crafto/categories
Content-Type: application/json
Authorization: Bearer {{bearerToken}}


### ===== FEED / HOME =====

### Get Crafto Feed - First Page (Local)
# Fetches the most recent crafto quotes
# 
# Query Parameters:
# - cursor: (Recommended) Base64 encoded cursor for pagination
#           Use the 'cursor' value from the previous response for the next page
# - offset: (Deprecated) Offset string in YYYYMMDDHH format (IST timezone)
#           If not provided, returns most recent quotes
# - limit: (optional) Number of items per page (default: 20, max: 100)
# - category: (optional) Category type filter (e.g., "motivational", "funny")
# 
# Response (200 OK):
# {
#   "filterText": null,
#   "selectedFilterId": null,
#   "data": [
#     {
#       "type": "QUOTE",
#       "data": { ... raw_json content ... }
#     },
#     ...
#   ],
#   "offset": "2026011615",  // Deprecated: Use cursor instead
#   "cursor": "eyJ0aW1lc3RhbXAiOiIyMDI2LTAxLTE2VDE1OjAwOjAwLjAwMFoiLCJpZCI6MTIzfQ==",  // Use this for next page
#   "hasMore": true,  // Indicates if there are more items to load
#   "limit": 20,
#   "popup": null,
#   "isBuggyFeedAlertWhitelisted": false,
#   "configuration": {
#     "logImageLoadExceptionEvents": true,
#     "logImageLoadSuccessEvent": false,
#     "logVideoExceptionEvent": true,
#     "logVideoLoadSuccessEvent": false
#   }
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
GET {{localUrl}}/crafto/home/v1.7
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get Crafto Feed - First Page (Production)
GET {{baseUrl}}/crafto/home/v1.7
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get Crafto Feed - With Custom Limit (Local)
# Fetch 50 items per page
GET {{localUrl}}/crafto/home/v1.7?limit=50
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get Crafto Feed - Next Page with Cursor (Local) - RECOMMENDED
# Infinite Scroll: Use the cursor from previous response to get next page
# This is the RECOMMENDED approach for infinite scroll
# Example cursor: eyJ0aW1lc3RhbXAiOiIyMDI2LTAxLTE2VDE1OjAwOjAwLjAwMFoiLCJpZCI6MTIzfQ==
GET {{localUrl}}/crafto/home/v1.7?cursor=PASTE_CURSOR_FROM_PREVIOUS_RESPONSE&limit=20
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get Crafto Feed - With Offset (Local) - DEPRECATED
# Pagination: Use the offset from previous response to get next page
# Example offset: 2026011612 (YYYYMMDDHH in IST)
# NOTE: This method is deprecated. Use cursor-based pagination instead.
GET {{localUrl}}/crafto/home/v1.7?offset=2026011612&limit=20
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get Crafto Feed - With Category Filter (Local)
# Filter by category type
GET {{localUrl}}/crafto/home/v1.7?category=motivational&limit=20
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

### Get Crafto Feed - With All Parameters (Production)
GET {{baseUrl}}/crafto/home/v1.7?cursor=PASTE_CURSOR_FROM_PREVIOUS_RESPONSE&limit=30&category=funny
Content-Type: application/json
Authorization: Bearer {{bearerToken}}



### ===== VIDEO OVERLAY =====

### Video Overlay - Health Check (Local)
# Returns service status and configuration
# 
# Response (200 OK):
# {
#   "status": "ok",
#   "service": "video-overlay",
#   "maxVideoSize": 104857600,
#   "maxOverlays": 10,
#   "supportedVideoFormats": [".mp4", ".mov", ".avi"],
#   "supportedImageFormats": [".png", ".jpg", ".jpeg"]
# }
GET {{localUrl}}/video/overlay
Content-Type: application/json

### Video Overlay - Health Check (Production)
GET {{baseUrl}}/video/overlay
Content-Type: application/json

### Video Overlay - Process Video (Local)
# Processes a video with custom overlays (images/text)
# Requires authentication via Bearer token
# 
# Request Body:
# {
#   "videoUrl": "https://example.com/video.mp4",
#   "overlays": [
#     {
#       "type": "image",
#       "imageUrl": "https://example.com/image.png",
#       "imageShape": "CIRCLE",  // or "RECTANGLE", "ROUNDED_RECTANGLE", "BLURRED CIRCLE"
#       "x": 10,
#       "y": 10,
#       "width": 100,
#       "height": 100,
#       "startTime": 0,
#       "endTime": 5
#     },
#     {
#       "type": "text",
#       "text": "Hello World",
#       "x": 50,
#       "y": 50,
#       "fontSize": 24,
#       "fontColor": "#FFFFFF",
#       "startTime": 0,
#       "endTime": 10
#     }
#   ]
# }
# 
# Response (200 OK):
# {
#   "success": true,
#   "videoUrl": "https://storage.googleapis.com/...",
#   "processingTime": 5423
# }
# 
# Response (400 Bad Request):
# {
#   "error": "videoUrl is required"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
# 
# Response (500 Internal Server Error):
# {
#   "success": false,
#   "error": "Video processing failed",
#   "processingTime": 1234
# }
POST {{localUrl}}/video/overlay
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "videoUrl": "https://storage.googleapis.com/alertpay-videos/sample-video.mp4",
  "overlays": [
    {
      "type": "image",
      "imageUrl": "https://example.com/logo.png",
      "imageShape": "CIRCLE",
      "x": 10,
      "y": 10,
      "width": 100,
      "height": 100,
      "startTime": 0,
      "endTime": 5
    },
    {
      "type": "text",
      "text": "Sample Overlay",
      "x": 50,
      "y": 200,
      "fontSize": 32,
      "fontColor": "#FFFFFF",
      "startTime": 0,
      "endTime": 10
    }
  ]
}

### Video Overlay - Process Video (Production)
POST {{baseUrl}}/video/overlay
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "videoUrl": "https://storage.googleapis.com/alertpay-videos/sample-video.mp4",
