    }
  ]
}

### ===== VIDEO OVERLAY V1 (Python Backend Proxy) =====
### Note: This endpoint proxies all video overlay requests to the Python backend
### for advanced video processing capabilities

### Video Overlay V1 - Health Check (Local)
# Health check that proxies to Python backend
# 
# Response (200 OK) - Python backend is healthy:
# {
#   "status": "ok",
#   "service": "video-overlay-python"
# }
# 
# Response (503 Service Unavailable) - Python backend unavailable:
# {
#   "status": "error",
#   "service": "video-overlay",
#   "error": "Python backend unavailable",
#   "backendUrl": "http://localhost:8000"
# }
GET {{localUrl}}/video/overlay/v1
Content-Type: application/json

### Video Overlay V1 - Health Check (Production)
GET {{baseUrl}}/video/overlay/v1
Content-Type: application/json


### ===== VIDEO OVERLAY BY CONTENT ID =====
### Simplified endpoint - processes video using pre-configured overlay settings
### Only requires contentId and image (URL or base64 data)

### Video Overlay By Content ID - Process (Local)
# Processes a video with pre-configured overlay settings from database
# Only requires contentId and the image to overlay
# Overlay position, timing, and shape are fetched from DB using contentId
# Requires authentication via Bearer token
# 
# Request Body:
# {
#   "contentId": "quote_123",
#   "imageUrl": "https://example.com/image.png"
# }
# 
# OR with base64 image data:
# {
#   "contentId": "quote_123",
#   "imageData": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAAB..."
# }
# 
# Response (200 OK):
# {
#   "success": true,
#   "videoUrl": "https://storage.googleapis.com/...",
#   "processingTime": 5423
# }
# 
# Response (400 Bad Request):
# {
#   "error": "contentId is required"
# }
# OR
# {
#   "error": "Either imageUrl or imageData must be provided"
# }
# 
# Response (401 Unauthorized):
# {
#   "error": "Unauthorized - no valid session"
# }
# 
# Response (500 Internal Server Error):
# {
#   "success": false,
#   "error": "Video processing failed",
#   "processingTime": 1234
# }
POST {{baseUrl}}/video/overlay/by-content-id
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "contentId": "6601915",
  "imageUrl": "https://cnd.storyowl.app/jamun-andriod/WoIHGy328w69P33Tw3HfRngLRpemvUyP/user-images/1769753529380_pfp_1769753528864.png"
}

### Video Overlay By Content ID - With Base64 Image (Local)
POST {{baseUrl}}/video/overlay/by-content-id
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "contentId": "6602187",
  "imageData": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
}

### Video Overlay By Content ID - Process (Production)
POST {{localUrl}}/video/overlay/by-content-id
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "contentId": "6391860",
